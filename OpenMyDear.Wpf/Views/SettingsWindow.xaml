<Window x:Class="OpenMyDear.Wpf.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenMyDear - Settings"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="760"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Style="{StaticResource DialogCardStyle}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="4"
                       Text="{Binding Localizer[Settings]}"
                       Style="{StaticResource SectionHeaderTextStyle}"
                       Margin="0,0,0,16" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,12" Text="{Binding Localizer[RunAtStartup]}" VerticalAlignment="Center" />
            <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding AutostartEnabled, Mode=TwoWay}" />

            <TextBlock Grid.Row="1" Grid.Column="2" Margin="18,0,8,12" Text="{Binding Localizer[AlwaysOnTop]}" VerticalAlignment="Center" />
            <CheckBox Grid.Row="1" Grid.Column="3" Margin="0,0,0,12" Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding AlwaysOnTop, Mode=TwoWay}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,12" Text="{Binding Localizer[Language]}" VerticalAlignment="Center" />
            <ComboBox Grid.Row="2"
                      Grid.Column="1"
                      Margin="0,0,8,12"
                      Width="170"
                      SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                      ItemsSource="{Binding SupportedLanguages}" />

            <TextBlock Grid.Row="2" Grid.Column="2" Margin="18,0,8,12" Text="{Binding Localizer[Theme]}" VerticalAlignment="Center" />
            <ComboBox Grid.Row="2"
                      Grid.Column="3"
                      Margin="0,0,0,12"
                      Width="120"
                      SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                      ItemsSource="{Binding SupportedThemes}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,12" Text="{Binding Localizer[StorageDirectory]}" VerticalAlignment="Center" />
            <TextBox Grid.Row="3"
                     Grid.Column="1"
                     Grid.ColumnSpan="2"
                     Margin="0,0,8,12"
                     IsReadOnly="True"
                     Text="{Binding StorageDirectory}" />
            <StackPanel Grid.Row="3" Grid.Column="3" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Width="72"
                        Margin="0,0,8,0"
                        Content="{Binding Localizer[Browse]}"
                        Command="{Binding BrowseStorageDirectoryCommand}" />
                <Button Style="{StaticResource GhostButtonStyle}"
                        Width="64"
                        Content="{Binding Localizer[Clear]}"
                        Command="{Binding ClearStorageDirectoryCommand}" />
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButtonStyle}" IsCancel="True" Width="100" Content="{Binding Localizer[Close]}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

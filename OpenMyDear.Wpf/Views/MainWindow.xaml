<Window x:Class="OpenMyDear.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OpenMyDear.Wpf"
        Height="700"
        Width="1100"
        MinHeight="600"
        MinWidth="950">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" Text="Profiles" />

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="Add" Width="80" Margin="0,0,8,0" Command="{Binding AddProfileCommand}" />
                    <Button Content="Delete" Width="80" Command="{Binding RemoveProfileCommand}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         DisplayMemberPath="Name" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <GroupBox Header="Profile" Grid.Row="0" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Name" />
                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             Margin="0,0,0,8"
                             IsEnabled="{Binding HasSelectedProfile}"
                             Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Launch Mode" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,0,0,8"
                              IsEnabled="{Binding HasSelectedProfile}"
                              ItemsSource="{Binding LaunchModes}"
                              SelectedItem="{Binding SelectedProfile.LaunchMode, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Delay Seconds" />
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             IsEnabled="{Binding HasSelectedProfile}"
                             Text="{Binding SelectedProfile.DelaySeconds, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </GroupBox>

            <GroupBox Header="Items" Grid.Row="2" Padding="10" Margin="0,0,0,10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Add Item" Width="100" Margin="0,0,8,0" Command="{Binding AddItemCommand}" />
                        <Button Content="Remove Item" Width="110" Command="{Binding RemoveItemCommand}" />
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding SelectedProfile.Items}"
                              SelectedItem="{Binding SelectedItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsEnabled="{Binding HasSelectedProfile}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Label"
                                                Width="180"
                                                Binding="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="Path"
                                                Width="*"
                                                Binding="{Binding Path, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridComboBoxColumn Header="Type"
                                                    Width="120"
                                                    SelectedItemBinding="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{Binding DataContext.ItemTypes, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Run"
                        Width="120"
                        Height="32"
                        Command="{Binding RunProfileCommand}" />
            </StackPanel>

            <GroupBox Grid.Row="4" Header="Run Result" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding RunStatus}"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding RunErrors}" MinHeight="100" />
                </DockPanel>
            </GroupBox>
        </Grid>
    </Grid>
</Window>

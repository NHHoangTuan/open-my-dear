<Window x:Class="OpenMyDear.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OpenMyDear.Wpf"
        Topmost="{Binding AlwaysOnTop, Mode=TwoWay}"
        Height="760"
        Width="1220"
        MinHeight="640"
        MinWidth="980">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           FontWeight="SemiBold"
                           FontSize="16"
                           Margin="0,0,0,10"
                           Text="{Binding Localizer[Profiles]}" />

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="{Binding Localizer[Add]}" Width="80" Margin="0,0,8,0" Command="{Binding AddProfileCommand}" />
                    <Button Content="{Binding Localizer[Delete]}" Width="80" Command="{Binding RemoveProfileCommand}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         DisplayMemberPath="Name" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <GroupBox Header="{Binding Localizer[Settings]}" Grid.Row="0" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="{Binding Localizer[RunAtStartup]}" />
                    <CheckBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" IsChecked="{Binding AutostartEnabled, Mode=TwoWay}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="{Binding Localizer[AlwaysOnTop]}" />
                    <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" IsChecked="{Binding AlwaysOnTop, Mode=TwoWay}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="{Binding Localizer[Language]}" />
                    <ComboBox Grid.Row="2"
                              Grid.Column="1"
                              Margin="0,0,0,8"
                              Width="150"
                              SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                              ItemsSource="{Binding SupportedLanguages}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="{Binding Localizer[StorageDirectory]}" />
                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             Margin="0,0,8,0"
                             IsReadOnly="True"
                             Text="{Binding StorageDirectory}" />
                    <Button Grid.Row="3"
                            Grid.Column="2"
                            Margin="0,0,8,0"
                            Width="90"
                            Content="{Binding Localizer[Browse]}"
                            Command="{Binding BrowseStorageDirectoryCommand}" />
                    <Button Grid.Row="3"
                            Grid.Column="3"
                            Width="90"
                            Content="{Binding Localizer[Clear]}"
                            Command="{Binding ClearStorageDirectoryCommand}" />
                </Grid>
            </GroupBox>

            <GroupBox Header="{Binding Localizer[Profile]}" Grid.Row="1" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="{Binding Localizer[Name]}" />
                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             Margin="0,0,0,8"
                             IsEnabled="{Binding HasSelectedProfile}"
                             Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="{Binding Localizer[LaunchMode]}" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,0,0,8"
                              IsEnabled="{Binding HasSelectedProfile}"
                              ItemsSource="{Binding LaunchModes}"
                              SelectedItem="{Binding SelectedProfile.LaunchMode, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Localizer[DelaySeconds]}" />
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             IsEnabled="{Binding HasSelectedProfile}"
                             Text="{Binding SelectedProfile.DelaySeconds, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </GroupBox>

            <GroupBox Header="{Binding Localizer[Items]}" Grid.Row="2" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding SelectedProfile.Items}"
                              SelectedItem="{Binding SelectedItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              Margin="0,0,0,10"
                              IsEnabled="{Binding HasSelectedProfile}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding Localizer[Label]}"
                                                Width="180"
                                                Binding="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="{Binding Localizer[Path]}"
                                                Width="*"
                                                Binding="{Binding Path, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTemplateColumn Header="{Binding Localizer[Type]}" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.ItemTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  MinWidth="120" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="{Binding Localizer[OpenWithPath]}" />
                        <TextBox Grid.Column="1"
                                 Margin="0,0,8,0"
                                 IsEnabled="{Binding HasSelectedItem}"
                                 Text="{Binding SelectedItem.OpenWith, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2"
                                Width="90"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding HasSelectedItem}"
                                Content="{Binding Localizer[PickApp]}"
                                Command="{Binding PickOpenWithCommand}" />
                        <Button Grid.Column="3"
                                Width="90"
                                IsEnabled="{Binding HasSelectedItem}"
                                Content="{Binding Localizer[Clear]}"
                                Command="{Binding ClearOpenWithCommand}" />
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Content="{Binding Localizer[AddItem]}" Width="100" Margin="0,0,8,0" Command="{Binding AddItemCommand}" />
                        <Button Content="{Binding Localizer[RemoveItem]}" Width="110" Command="{Binding RemoveItemCommand}" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="{Binding Localizer[Run]}"
                        Width="120"
                        Height="32"
                        Command="{Binding RunProfileCommand}" />
            </StackPanel>

            <GroupBox Grid.Row="4" Header="{Binding Localizer[RunResult]}" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding RunStatus}"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding RunErrors}" MinHeight="100" />
                </DockPanel>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
